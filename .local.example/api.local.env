PCP_APP_NAME=proxy-control-plane
PCP_ENVIRONMENT=local
PCP_LISTEN_ADDR=:9710
PCP_DATABASE_URL=postgres://proxy_control_app:change-me@127.0.0.1:5432/proxy_control?sslmode=disable
PCP_ADMIN_EMAIL=admin@example.com
PCP_ADMIN_PASSWORD=change-me-admin-password
PCP_SECRET_KEY=change-me-with-openssl-rand-base64-32
PCP_ACCESS_TOKEN_EXPIRE_MINUTES=60
PCP_AUTO_CREATE_DATABASE=true
PCP_AUTO_MIGRATE=true
